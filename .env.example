# Copy to .env and fill in real keys

# Notion integration token. Create at https://www.notion.so/profile/integrations
# Then connect the integration to the Job Hunt HQ page so it can read/write Companies + Sourced Roles
NOTION_TOKEN=secret_xxx

# Anthropic API key (you have this)
ANTHROPIC_API_KEY=sk-ant-xxx

# Optional: max companies to query per run (start small, scale up)
MAX_COMPANIES_PER_RUN=20

# Optional: which tiers to query (comma-separated). Leave empty for all.
# T1, T2, T3, T4, T5, T6, T7, T8
TIERS=T1,T3,T8

# Optional: which JobSpy sites to scrape (comma-separated).
# Valid: linkedin, indeed, glassdoor, google, zip_recruiter, bayt, naukri
SCRAPER_SITES=linkedin,indeed,glassdoor,google

# Optional: country for Indeed/Glassdoor (they're country-specific domains).
SCRAPER_COUNTRY=Israel
